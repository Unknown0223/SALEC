{
  "name": "frontend",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "cross-env NEXT_IGNORE_INCORRECT_LOCKFILE=1 next dev -p 3000",
    "dev:clean": "node clean-next.cjs && cross-env NEXT_IGNORE_INCORRECT_LOCKFILE=1 next dev -p 3000",
    "clean": "node clean-next.cjs",
    "build": "next build",
    "start": "next start -H 0.0.0.0",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ci": "npm run typecheck && vitest run",
    "test:quality": "npm run typecheck && npm run lint && npm run test",
    "test:e2e": "playwright test",
    "test:e2e:smoke": "playwright test e2e/login-smoke.spec.ts e2e/dashboard-shell-smoke.spec.ts e2e/dashboard-routes-smoke.spec.ts e2e/orders-payments-shell-smoke.spec.ts e2e/payment-allocate-order-status-smoke.spec.ts",
    "test:e2e:ci": "cross-env CI=true playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:install": "playwright install chromium",
    "test:all": "npm run test:quality && npm run test:e2e:smoke"
  },
  "dependencies": {
    "@base-ui/react": "^1.3.0",
    "@radix-ui/react-select": "^2.2.6",
    "@tanstack/react-query": "^5.95.2",
    "axios": "^1.14.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "leaflet": "^1.9.4",
    "lucide-react": "^1.7.0",
    "next": "14.2.35",
    "react": "^18",
    "react-dom": "^18",
    "react-leaflet": "^4.2.1",
    "recharts": "^2.15.4",
    "shadcn": "^4.1.1",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0",
    "xlsx": "^0.18.5",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.0.1",
    "@types/leaflet": "^1.9.21",
    "@types/node": "^20",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "@vitejs/plugin-react": "^4.3.4",
    "cross-env": "^7.0.3",
    "eslint": "^8",
    "eslint-config-next": "14.2.35",
    "jsdom": "^25.0.1",
    "postcss": "^8",
    "tailwindcss": "^3.4.1",
    "typescript": "^5",
    "vitest": "^2.1.8"
  }
}
