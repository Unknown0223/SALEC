{
  "name": "savdo-backend",
  "version": "0.1.0",
  "private": true,
  "type": "commonjs",
  "scripts": {
    "postinstall": "prisma generate",
    "predev": "node scripts/wait-for-postgres.cjs && prisma migrate deploy && prisma generate",
    "dev": "tsx watch src/index.ts",
    "dev:server": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "test": "vitest",
    "test:ci": "vitest run",
    "db:migrate": "prisma migrate dev",
    "db:deploy": "prisma migrate deploy",
    "db:seed": "prisma db seed",
    "db:studio": "prisma studio",
    "db:generate": "prisma generate",
    "audit:retention": "tsx scripts/audit-retention.ts",
    "audit:territory-codes": "tsx scripts/audit-territory-codes.ts",
    "import:refs": "tsx scripts/import-reference-bundle.ts",
    "import:staff-csv": "tsx scripts/import-staff-from-csv.ts",
    "ensure:demo-logins": "tsx scripts/ensure-demo-staff-login.ts",
    "import:once": "tsx scripts/import-once.ts",
    "import:cities-xlsx": "tsx scripts/import-cities-xlsx.ts",
    "import:territory-excel": "tsx scripts/import-territory-excel.ts",
    "territory:sync-codes": "tsx scripts/sync-territory-codes.ts",
    "seed:agent-gps-once": "tsx scripts/seed-agent-gps-pings-once.ts"
  },
  "dependencies": {
    "@fastify/cors": "^9.0.1",
    "@fastify/jwt": "^8.0.1",
    "@fastify/multipart": "^8.3.0",
    "@fastify/rate-limit": "^9.1.0",
    "@prisma/client": "^6.0.0",
    "bcryptjs": "^3.0.2",
    "dotenv": "^16.4.5",
    "exceljs": "^4.4.0",
    "fastify": "^4.28.1",
    "fastify-plugin": "^5.0.1",
    "ioredis": "^5.10.1",
    "pdfkit": "^0.18.0",
    "pino-pretty": "^13.0.0",
    "xlsx": "^0.18.5",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^22.10.1",
    "@types/pdfkit": "^0.17.5",
    "@types/readable-stream": "^4.0.23",
    "prisma": "^6.0.0",
    "supertest": "^7.1.1",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
